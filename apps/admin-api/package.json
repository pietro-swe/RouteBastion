{
	"name": "admin-api",
	"version": "0.0.1",
	"description": "Administration API for RouteBastion Admin Panel",
	"author": {
		"name": "Pietro Piva Vieira",
		"email": "pietro.developer@gmail.com",
		"url": "https://github.com/pietro-swe"
	},
	"private": true,
	"license": "MIT",
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
		"test:e2e": "vitest run --config ./vitest.config.e2e.ts"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/platform-fastify": "^11.1.19",
		"@nestjs/swagger": "^11.3.2",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"nestjs-zod": "^5.3.0",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.15.26",
		"@types/node": "^24.0.0",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.0.0",
		"@vitest/coverage-v8": "^4.1.4",
		"drizzle-kit": "^0.31.10",
		"globals": "^17.0.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3",
		"unplugin-swc": "^1.5.9",
		"vitest": "^4.1.4"
	}
}
